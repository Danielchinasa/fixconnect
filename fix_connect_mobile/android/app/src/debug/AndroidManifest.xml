<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- INTERNET permission is required for the Flutter tool (hot reload / DevTools)
         and for network requests during development. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Allow plain HTTP in debug builds only.
         The dev API runs on http://localhost (or http://10.0.2.2 on emulator).
         This flag is NOT present in the release manifest, so production
         traffic must use HTTPS. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
